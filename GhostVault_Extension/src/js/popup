<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>GhostVault</title>
  <style>
    :root {
      /* GhostVault Design System - Dark Theme with Glassmorphism */
      --bg: #0f1724; /* deep navy */
      --panel: #111827; /* almost black */
      --muted: #9aa4b2;
      --surface: #0b1220;
      --accent: #22c1c3; /* ghost teal */
      --accent-2: #7dd3fc; /* light cyan for highlights */
      --success: #28c76f;
      --danger: #ff6b6b;
      --glass: rgba(255, 255, 255, 0.03);
      --radius: 12px;
      --gap: 14px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      color-scheme: dark;
    }
    
    * {
      box-sizing: border-box;
      transition: border-color 0.2s ease, background-color 0.2s ease;
    }
    
    body {
      margin: 0;
      padding: 0;
      min-width: 420px;
      min-height: 450px;
      max-height: 600px;
      background: linear-gradient(180deg, var(--bg), #071123);
      color: #e6eef3;
    }
    /* Main container with glassmorphism effect */
    .container {
      width: 420px;
      max-width: 94vw;
      margin: 18px auto;
      padding: 18px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01));
      border-radius: 16px;
      box-shadow: 0 8px 30px rgba(2, 6, 23, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    /* Header layout */
    header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    
    /* Logo with gradient background */
    .logo {
      width: 56px;
      height: 56px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #031018;
      font-size: 18px;
    }
    
    /* Typography styles */
    .title {
      font-size: 18px;
      font-weight: 700;
      color: #e6eef3;
    }
    
    .subtitle {
      font-size: 12px;
      color: var(--muted);
    }
    .tip {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.01), rgba(255, 255, 255, 0.015));
      color: var(--accent-2);
      padding: 12px 16px;
      border-radius: var(--radius);
      margin-bottom: 16px;
      font-size: 0.9rem;
      border: 1px solid rgba(255, 255, 255, 0.03);
      box-shadow: 0 4px 12px rgba(34, 193, 195, 0.04);
    }
    .section {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.01), rgba(255, 255, 255, 0.015));
      border-radius: var(--radius);
      margin-bottom: 16px;
      padding: 16px;
      border: 1px solid rgba(255, 255, 255, 0.03);
    }
    .section h2 {
      font-size: 1.1rem;
      margin: 0 0 12px 0;
      color: #e6eef3;
      letter-spacing: 0.5px;
    }
    /* Tab navigation styles */
    .tab-bar {
      display: flex;
      gap: 8px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }
    
    /* Individual tab styling with hover and active states */
    .tab {
      padding: 8px 12px;
      border-radius: 10px;
      background: var(--glass);
      cursor: pointer;
      font-weight: 600;
      color: var(--muted);
      font-size: 13px;
      transition: all 0.2s ease;
      border: 1px solid transparent;
    }
    
    .tab:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(34, 193, 195, 0.2);
    }
    
    /* Active tab with accent gradient and glow effect */
    .tab.active {
      background: linear-gradient(90deg, rgba(34, 193, 195, 0.12), rgba(125, 211, 252, 0.06));
      color: var(--accent-2);
      box-shadow: 0 6px 18px rgba(34, 193, 195, 0.06);
      border-color: rgba(34, 193, 195, 0.3);
    }
    
    .tab-bar button {
      padding: 8px 12px;
      border-radius: 10px;
      background: var(--glass);
      cursor: pointer;
      font-weight: 600;
      color: var(--muted);
      font-size: 13px;
      transition: all 0.2s ease;
      border: 1px solid transparent;
    }
    
    .tab-bar button:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(34, 193, 195, 0.2);
    }
    
    .tab-bar button.active, .tab-bar button:focus {
      background: linear-gradient(90deg, rgba(34, 193, 195, 0.12), rgba(125, 211, 252, 0.06));
      color: var(--accent-2);
      box-shadow: 0 6px 18px rgba(34, 193, 195, 0.06);
      border-color: rgba(34, 193, 195, 0.3);
    }
    .tab-content {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.01), rgba(255, 255, 255, 0.015));
      border-radius: var(--radius);
      padding: 14px;
      min-height: 120px;
      border: 1px solid rgba(255, 255, 255, 0.03);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 12px;
      font-size: 0.9rem;
    }
    th, td {
      padding: 8px 6px;
      text-align: left;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    th {
      background: rgba(34, 193, 195, 0.1);
      color: var(--accent-2);
      font-weight: 600;
    }
    tr:last-child td {
      border-bottom: none;
    }
    td {
      color: #e6eef3;
    }
    /* Global button styles matching the design system */
    button {
      border: none;
      padding: 10px 12px;
      border-radius: 10px;
      font-weight: 700;
      cursor: pointer;
      font-size: 13px;
      transition: all 0.2s ease;
      font-family: inherit;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #031018;
    }
    
    .btn-primary:hover, .btn-primary:focus {
      background: linear-gradient(135deg, var(--accent-2), var(--accent));
      transform: translateY(-1px);
    }
    
    .btn-danger {
      background: var(--danger);
      color: #fff;
    }
    .btn-danger:hover, .btn-danger:focus {
      background: #ff5252;
      transform: translateY(-1px);
    }
    .btn-success {
      background: var(--success);
      color: #fff;
    }
    .btn-success:hover, .btn-success:focus {
      background: #4caf50;
      transform: translateY(-1px);
    }
    .btn-ghost {
      background: transparent;
      border: 1px solid var(--glass);
      color: var(--muted);
    }
    .btn-ghost:hover, .btn-ghost:focus {
      border-color: var(--accent);
      color: var(--accent);
    }
    ul, li {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .aria-desc {
      font-size: 0.9rem;
      color: var(--muted);
      margin: 6px 12px 0 12px;
      text-align: center;
    }
    
    #settingsBtn {
      width: 40px;
      height: 40px;
      padding: 0;
      font-size: 18px;
      line-height: 40px;
      position: fixed;
      bottom: 16px;
      right: 16px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #031018;
      border: none;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(34, 193, 195, 0.3);
      transition: all 0.3s ease;
    }
    
    #settingsBtn:hover, #settingsBtn:focus {
      background: linear-gradient(135deg, var(--accent-2), var(--accent));
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(34, 193, 195, 0.4);
    }
    /* Input field styling */
    input[type="email"], input[type="text"], input[type="password"], input[type="url"], textarea {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 10px 12px;
      color: #e6eef3;
      font-size: 14px;
      width: 100%;
      margin-bottom: 8px;
      transition: all 0.2s ease;
    }
    
    input[type="email"]:focus, input[type="text"]:focus, input[type="password"]:focus, input[type="url"]:focus, textarea:focus {
      outline: none;
      border-color: var(--accent);
      background: rgba(255, 255, 255, 0.04);
      box-shadow: 0 0 0 2px rgba(34, 193, 195, 0.1);
    }
    
    input::placeholder, textarea::placeholder {
      color: var(--muted);
    }
    
    /* Responsive design for mobile devices */
    @media (max-width: 480px) {
      .container {
        padding: 12px;
        margin: 12px auto;
      }
      
      .tab-bar {
        gap: 6px;
      }
      
      .tab, .tab-bar button {
        padding: 6px 8px;
        font-size: 12px;
      }
    }
    
    /* Accessibility: Focus styles for keyboard navigation */
    .tab:focus,
    button:focus,
    input:focus,
    textarea:focus {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    
    /* Message animation */
    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
    
    /* Status chips for overview section */
    .chip {
      display: inline-block;
      padding: 6px 8px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.02);
      font-weight: 600;
      font-size: 12px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    /* Risk level indicators */
    .risk-low {
      color: var(--success);
      font-weight: 700;
    }
    
    .risk-high {
      color: var(--danger);
      font-weight: 700;
    }
    
    .small {
      font-size: 12px;
      color: var(--muted);
    }
  </style>
</head>
<body>
  <div class="container" role="application" aria-label="GhostVault Privacy Toolkit">
    <header class="flex items-center gap-3">
      <div class="logo">GV</div>
      <div>
        <div class="title">GhostVault</div>
        <div class="subtitle">Privacy toolkit — Browser Extension</div>
      </div>
    </header>
    
    <div class="tip" id="tip" aria-live="polite">Loading tip...</div>
    <div class="section" aria-label="Quick Tools">
      <div>
        <input id="emailInput" type="email" placeholder="Enter your email" aria-label="Email address for breach check" />
        <button id="breachBtn" aria-label="Check if email is breached" class="btn-success">🔍 Check Breach</button>
        <div id="breachResult" aria-live="polite"></div>
      </div>
      <div style="margin-top:12px; display:flex; gap:8px; flex-wrap: wrap;">
        <button id="termsBtn" aria-label="Analyze Terms and Conditions" class="btn-primary">📜 Analyze T&Cs</button>
        <button id="loginBtn" aria-label="Open Login Manager" class="btn-primary">🔐 Login Manager</button>
      </div>
      <div id="tcAnalyzer" style="display:none; margin-top:16px;" aria-label="Terms and Conditions Analyzer">
        <label for="tcInput" style="color: var(--muted); font-size: 13px; margin-bottom: 8px; display: block;">Paste Terms & Conditions: <span title="Paste the text of the website's terms and conditions here for analysis">❓</span></label>
        <textarea id="tcInput" rows="6" placeholder="Paste T&C text here..." aria-label="Terms and Conditions text"></textarea>
        <button id="analyzeTcBtn" aria-label="Analyze T&Cs" class="btn-primary" style="margin-top:8px;">Analyze T&Cs</button>
        <div id="tcResult" aria-live="polite"></div>
        <div id="tcActions" style="margin-top:12px; display:none;"></div>
      </div>
      <div id="loginManager" style="display:none; margin-top: 16px;" aria-label="Login Manager">
        <h3 style="margin:0 0 12px 0; color:#e6eef3;">Login Manager</h3>
        <form id="loginForm" aria-label="Save a new login">
          <input type="url" id="loginUrl" placeholder="Website URL (e.g. https://example.com)" required aria-label="Website URL" />
          <input type="text" id="loginUser" placeholder="Username or Email" required aria-label="Username or Email" />
          <input type="password" id="loginPass" placeholder="Password" required aria-label="Password" />
          <span title="This password will be encrypted with your master password. Don't forget your master password!" style="color: var(--muted);">❓</span>
          <div style="margin-top:8px;">
            <button type="submit" aria-label="Save Login" class="btn-primary">Save Login</button>
          </div>
        </form>
        <h4 style="margin:16px 0 8px 0; color:#e6eef3;">Saved Logins:</h4>
        <ul id="savedLogins" style="list-style: none; padding-left: 0;"></ul>
      </div>
    </div>
    <div class="section" id="dataManager" aria-label="Data Manager">
      <h2>Data Manager</h2>
      <div class="tab-bar" role="tablist">
        <button id="tabLogins" role="tab" aria-selected="true" tabindex="0">Logins</button>
        <button id="tabScans" role="tab" aria-selected="false" tabindex="0">T&C/Cookie Scans</button>
        <button id="tabNever" role="tab" aria-selected="false" tabindex="0">Never Save Sites</button>
        <button id="tabExport" role="tab" aria-selected="false" tabindex="0">Export Data</button>
      </div>
      <div class="tab-content" id="tabContent" role="tabpanel"></div>
    </div>
    
    <footer class="flex justify-between items-center mt-3" style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255, 255, 255, 0.05);">
      <div class="small">Browser Extension — Privacy First</div>
      <a href="https://github.com/your-repo/ghostvault-extension#help" target="_blank" rel="noopener" style="color:var(--accent); text-decoration: none; font-size: 12px;" aria-label="Help and support">❓ Help & Support</a>
    </footer>
  </div>
  
  <button id="settingsBtn" title="Settings" aria-label="Open settings">⚙️</button>
  <div class="aria-desc" id="aria-desc">After clicking Get Started, you can open GhostVault from the browser toolbar.</div>
  <script src="db.js"></script>
  <!-- SQL.js for UI database (local) -->
  <script src="popup.js"></script>
</body>
</html>
